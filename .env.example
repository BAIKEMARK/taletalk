# TaleTalk 抽取阶段使用的 LLM API 配置。
# 复制为 .env，按需填一个平台即可。也可以同时填多个，notebook 里用 LLM_PLATFORM 切换。

# 默认走哪个平台。可选: deepseek / openai / siliconflow / moonshot / custom
LLM_PLATFORM=custom

# --- DeepSeek ---
DEEPSEEK_API=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI (官方或任何标准 OpenAI 协议) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- SiliconFlow ---
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Custom / 自建 / 本地 vLLM / LLaMA Factory api server ---
# 任何 OpenAI 兼容协议都能走这里, 比如:
#   vLLM:           CUSTOM_BASE_URL=http://localhost:8000/v1
#   LLaMA Factory:  CUSTOM_BASE_URL=http://localhost:8000/v1
#   阶跃 (StepFun): CUSTOM_BASE_URL=https://api.stepfun.com/step_plan/v1  CUSTOM_MODEL=step-3.7-flash
CUSTOM_API_KEY=EMPTY
CUSTOM_BASE_URL=http://localhost:8000/v1
CUSTOM_MODEL=
