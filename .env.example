# TaleTalk 本地密钥配置。
# 复制为 .env 后填写；真实 .env 不提交到 Git。
# 这里集中管理：抽取/一轮生成 API、embedding、rerank。

# 默认走哪个平台。可选: deepseek / openai / siliconflow / moonshot / custom
LLM_PLATFORM=custom

# --- DeepSeek ---
DEEPSEEK_API=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=

# --- OpenAI (官方或任何标准 OpenAI 协议) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=

# --- SiliconFlow ---
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL_NAME=

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL_NAME=

# --- Custom / 自建 / 本地 vLLM / LLaMA Factory api server ---
# 任何 OpenAI 兼容协议都能走这里, 比如:
#   vLLM:           CUSTOM_BASE_URL=http://localhost:8000/v1
#   LLaMA Factory:  CUSTOM_BASE_URL=http://localhost:8000/v1
#   阶跃 (StepFun): CUSTOM_BASE_URL=https://api.stepfun.com/step_plan/v1  CUSTOM_MODEL_NAME=step-3.7-flash
CUSTOM_API_KEY=EMPTY
CUSTOM_BASE_URL=http://localhost:8000/v1
CUSTOM_MODEL_NAME=

# --- StepFun / 阶跃：推荐也同步到 CUSTOM_*，兼容旧脚本 ---
STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/step_plan/v1
STEPFUN_MODEL_NAME=step-3.7-flash

# --- TaleTalk one-pass teacher model ---
# 留空时使用 CUSTOM_* / STEPFUN_* / OPENAI_*。
TEACHER_API_KEY=
TEACHER_BASE_URL=
TEACHER_MODEL_NAME=

# --- Embedding service ---
# OpenAI-compatible embedding: POST {EMBEDDING_BASE_URL}/embeddings
# 并行智算云：EMBEDDING_PROVIDER=parallel_cloud，EMBEDDING_BASE_URL=https://$BASE_PATH/v1
EMBEDDING_PROVIDER=parallel_cloud
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_NAME=GLM-Embedding-3

# --- Reranker service ---
# Rerank: POST {RERANKER_BASE_URL}/rerank
# 并行智算云：RERANKER_PROVIDER=parallel_cloud，RERANKER_BASE_URL=https://$BASE_PATH/v1
# 实际请求地址会是 {RERANKER_BASE_URL}/p002/rerank
RERANKER_PROVIDER=parallel_cloud
RERANKER_API_KEY=
RERANKER_BASE_URL=
RERANKER_MODEL_NAME=GLM-Rerank
